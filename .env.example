# Copy to `.env` in this directory and set values. `.env` is gitignored.
# Docker Compose loads `.env` automatically for variable substitution.

# Default chat model for Ollama pull + backend (optional override).
OLLAMA_MODEL=qwen2.5:3b

# Optional: Ollama context length in tokens (spring.ai.ollama.chat.options.num-ctx). Default 32768 in compose/backend.
# Lower if you hit OOM or slow first-token (e.g. OLLAMA_NUM_CTX=16384).
# OLLAMA_NUM_CTX=16384

# Optional: enables the `web_search` tool on POST /api/chat (Tavily Search API).
# Get a key at https://tavily.com — free tier has monthly credits.
TAVILY_API_KEY=
